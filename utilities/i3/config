# i3 config file (v4)

set $mod Mod4

font pango:monospace 10

# -- Startup --
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id alacritty
exec --no-startup-id firefox
exec --no-startup-id thunar
exec --no-startup-id discord
exec --no-startup-id sleep 3 && i3-msg 'workspace "1"'
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id xrdb -merge ~/.Xresources
exec --no-startup-id xsetroot -cursor_name left_ptr
exec_always --no-startup-id xrandr \
    --output DisplayPort-0 --rotate left --pos 0x420 \
    --output DisplayPort-1 --rotate normal --pos 1080x0 --primary \
    --output HDMI-A-0 --rotate left --pos 3000x0
exec_always --no-startup-id feh --bg-fill ~/.config/i3/wallpaper.jpg 2>/dev/null || feh --bg-solid '#1a1a2e'

# -- Volume --
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

# -- Mouse --
floating_modifier $mod
tiling_drag modifier titlebar

# -- Applications --
bindsym $mod+Return exec alacritty
bindsym $mod+Shift+q kill
bindsym $mod+d exec --no-startup-id dmenu_run

# -- Focus (vim keys + arrows) --
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# -- Move windows --
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# -- Layout --
bindsym $mod+b split h
bindsym $mod+v split v
bindsym $mod+z fullscreen toggle
bindsym $mod+Shift+w layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent

# -- Workspaces --
# Named: center monitor
set $ws_term "terminal"
set $ws_browser "browser"
set $ws_files "files"
# Named: case display
set $ws_discord "discord"
# Numbered: center monitor
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
# Numbered: left vertical
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"

workspace $ws_term    output DisplayPort-1
workspace $ws_browser output DisplayPort-1
workspace $ws_files   output DisplayPort-0
workspace $ws_discord output DisplayPort-0
workspace $ws1 output DisplayPort-1
workspace $ws2 output DisplayPort-1
workspace $ws3 output DisplayPort-1
workspace $ws6 output DisplayPort-0
workspace $ws7 output DisplayPort-0
workspace $ws8 output DisplayPort-0

assign [class="Alacritty"] $ws_term
assign [class="firefox"]   $ws_browser
assign [class="Thunar"]    $ws_files
assign [class="discord"]   $ws_discord

# Named workspace keys
bindsym $mod+t workspace $ws_term
bindsym $mod+g workspace $ws_browser
bindsym $mod+f workspace $ws_files
bindsym $mod+s workspace $ws_discord

bindsym $mod+Shift+t move container to workspace $ws_term
bindsym $mod+Shift+g move container to workspace $ws_browser
bindsym $mod+Shift+f move container to workspace $ws_files
bindsym $mod+Shift+s move container to workspace $ws_discord

# Numbered workspace keys
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8

# -- i3 control --
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'Exit i3?' -B 'Yes, exit' 'i3-msg exit'"

# -- Resize mode --
mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# -- Bar --
bar {
        status_command i3status
        position top
}
