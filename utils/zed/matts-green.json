          "boolean":                { "color": "#34e2e2" },
          "comment":                { "color": "#555753", "font_style": "italic" },
          "comment.doc":            { "color": "#555753", "font_style": "italic" },
          "constant":               { "color": "#34e2e2" },
          "constructor":            { "color": "#34e2e2" },
