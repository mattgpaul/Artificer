          "enum":                   { "color": "#34e2e2" },
          "function":               { "color": "#04ff00" },
          "function.builtin":       { "color": "#04ff00" },
          "function.method":        { "color": "#04ff00" },
          "function.special":       { "color": "#04ff00" },
          "hint":                   { "color": "#555753" },
          "keyword":                { "color": "#eeeeec", "font_weight": 700 },
          "label":                  { "color": "#729fcf" },
          "link_text":              { "color": "#04ff00", "font_style": "italic" },
          "link_uri":               { "color": "#729fcf" },
          "number":                 { "color": "#34e2e2" },
          "operator":               { "color": "#eeeeec", "font_weight": 700 },
          "predictive":             { "color": "#555753", "font_style": "italic" },
          "preproc":                { "color": "#729fcf" },
          "primary":                { "color": "#04ff00" },
          "property":               { "color": "#04ff00" },
          "punctuation":            { "color": "#8ae234" },
          "punctuation.bracket":    { "color": "#8ae234" },
          "punctuation.delimiter":  { "color": "#8ae234" },
          "punctuation.list_marker":{ "color": "#8ae234" },
          "punctuation.special":    { "color": "#ef2929" },
          "string":                 { "color": "#c07830" },
          "string.escape":          { "color": "#ef2929" },
          "string.regex":           { "color": "#c07830" },
          "string.special":         { "color": "#ef2929" },
          "string.special.symbol":  { "color": "#ef2929" },
          "tag":                    { "color": "#729fcf" },
          "text.literal":           { "color": "#c07830" },
          "title":                  { "color": "#04ff00", "font_weight": 700 },
          "type":                   { "color": "#34e2e2" },
          "type.builtin":           { "color": "#34e2e2" },
          "variable":               { "color": "#04ff00" },
          "variable.builtin":       { "color": "#04ff00" },
          "variable.member":        { "color": "#04ff00" },
          "variable.parameter":     { "color": "#04ff00" },
          "variant":                { "color": "#34e2e2" }
