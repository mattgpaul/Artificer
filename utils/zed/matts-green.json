        "element.background":                 "#04ff0020",
        "element.hover":                      "#04ff0015",
        "element.active":                     "#04ff0030",
        "element.selected":                   "#04ff0030",
        "element.disabled":                   "#555753",
        "drop_target.background":             "#04ff0020",

        "ghost_element.background":           "#00000000",
        "ghost_element.hover":                "#04ff0015",
        "ghost_element.active":               "#04ff0030",
        "ghost_element.selected":             "#04ff0030",
        "ghost_element.disabled":             "#555753",

        "text":                               "#04ff00",
