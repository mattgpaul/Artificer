        "panel.background":                         "#000000",
        "panel.border":                             "#1a1a1a",
        "panelTitle.activeForeground":              "#04ff00",
        "panelTitle.activeBorder":                  "#04ff00",
        "panelTitle.inactiveForeground":            "#555753"
    },
    "tokenColors": [
        {
            "name": "Comments",
            "scope": ["comment", "punctuation.definition.comment", "string.quoted.docstring"],
            "settings": { "foreground": "#555753", "fontStyle": "italic" }
        },
        {
            "name": "Strings",
            "scope": ["string", "string.quoted", "string.template"],
            "settings": { "foreground": "#c07830" }
        },
        {
            "name": "Numbers and constants",
            "scope": ["constant.numeric", "constant.language", "constant.character"],
            "settings": { "foreground": "#34e2e2" }
        },
        {
            "name": "Keywords and storage",
            "scope": [
                "keyword", "keyword.control", "keyword.operator",
                "storage.type", "storage.modifier"
            ],
            "settings": { "foreground": "#eeeeec", "fontStyle": "bold" }
        },
        {
            "name": "Functions and methods",
            "scope": [
                "entity.name.function", "entity.name.method",
                "support.function", "meta.function-call"
            ],
            "settings": { "foreground": "#04ff00" }
        },
        {
            "name": "Types and classes",
            "scope": [
                "entity.name.type", "entity.name.class",
                "support.type", "support.class"
            ],
            "settings": { "foreground": "#34e2e2" }
        },
        {
            "name": "Preprocessor, imports, tags",
            "scope": [
                "keyword.control.import", "keyword.control.include",
                "meta.preprocessor", "entity.name.tag"
            ],
            "settings": { "foreground": "#729fcf" }
        },
        {
            "name": "Special characters and escapes",
            "scope": [
                "constant.character.escape", "punctuation.definition.string",
                "keyword.other.special-method"
            ],
            "settings": { "foreground": "#ef2929" }
        },
        {
            "name": "Variables and parameters",
            "scope": ["variable", "variable.parameter", "variable.other"],
            "settings": { "foreground": "#04ff00" }
        },
        {
            "name": "Punctuation",
            "scope": ["punctuation", "meta.brace"],
            "settings": { "foreground": "#8ae234" }
        },
        {
            "name": "Attributes and decorators",
            "scope": ["entity.other.attribute-name", "meta.decorator"],
            "settings": { "foreground": "#729fcf" }
        },
        {
            "name": "Errors",
            "scope": ["invalid", "invalid.illegal"],
            "settings": { "foreground": "#ef2929", "fontStyle": "underline" }
        }
    ]
}
