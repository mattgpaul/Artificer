{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Gemma (local llama.cpp)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "gemma-3-27b": {
          "name": "Gemma 3 27B (local)",
          "limit": {
            "context": 65536,
            "output": 16384
          }
        }
      }
    },
    "llama-coder": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen3-Coder (local llama.cpp)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "qwen3-coder": {
          "name": "Qwen3-Coder 30B-A3B (local)",
          "limit": {
            "context": 32768,
            "output": 16384
          },
          "compaction": {
              "threshold": 0.80,
              "logging": "error"
          }
        }
      }
    }
  },
}
