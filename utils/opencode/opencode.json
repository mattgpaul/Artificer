{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Gemma (local llama.cpp)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "gemma-3-27b": {
          "name": "Gemma 3 27B (local)",
          "limit": {
            "context": 65536,
            "output": 16384
          }
        }
      }
    },
    "llama-coder": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen3-Coder (local llama.cpp)",
      "options": {
        "baseURL": "http://127.0.0.1:8081/v1"
      },
      "models": {
        "qwen3-coder": {
          "name": "Qwen3-Coder 30B-A3B (local)",
          "limit": {
            "context": 32768,
            "output": 16384
          }
        }
      }
    }
  },
  "model": "llama-coder/qwen3-coder",
  "agent": {
    "review": {
      "mode": "subagent",
      "model": "llama-coder/qwen3-coder",
      "temperature": 0.1,
      "prompt": "You are a focused code reviewer. Report correctness bugs, edge cases, and simplifications. Be concise; do not modify files.",
      "permission": {
        "edit": "deny"
      }
    },
    "docs": {
      "mode": "subagent",
      "model": "llama-local/gemma-3-27b",
      "temperature": 0.3,
      "prompt": "You write and update documentation and code comments. Match the surrounding style and keep prose clear and concise."
    },
    "ask": {
      "mode": "primary",
      "model": "llama-coder/qwen3-coder",
      "temperature": 0.2,
      "prompt": "You explain and explore the codebase. Answer questions and trace how things work. Do not modify files.",
      "permission": {
        "edit": "deny"
      }
    }
  }
}
